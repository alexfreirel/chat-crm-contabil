# Forçar LF para scripts shell (evita CRLF quebrando shebang no Linux)
*.sh text eol=lf

# Outros arquivos de texto normais
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.prisma text eol=lf
*.env text eol=lf
*.sql text eol=lf
