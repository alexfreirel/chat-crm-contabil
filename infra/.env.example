# ============================================
# LexCon CRM Contábil - Variáveis de Ambiente
# Copie para .env na raiz do projeto e preencha
# Variáveis marcadas com [OBRIGATÓRIO] não têm fallback seguro
# ============================================

# ------ Ambiente ------
# [OBRIGATÓRIO em produção] Define o modo de execução
# Valores: development | production
# Em production: CORS aberto é bloqueado, variáveis críticas são exigidas
NODE_ENV=development

# ------ Banco de Dados ------
# [OBRIGATÓRIO] String de conexão PostgreSQL completa
DATABASE_URL=postgresql://crm_user:TROQUE_POR_SENHA_FORTE@localhost:5432/lexcon

POSTGRES_USER=crm_user
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
POSTGRES_DB=lexcon

# ------ JWT Auth ------
# [OBRIGATÓRIO] Chave secreta para assinar tokens JWT
# Gere com: openssl rand -base64 64
# O servidor recusa inicializar se esta variável estiver ausente
JWT_SECRET=TROQUE_POR_UMA_SECRET_FORTE_AQUI
JWT_EXPIRES_IN=15m

# ------ CORS (Segurança de Origem) ------
# [OBRIGATÓRIO em produção] Lista de origens permitidas separadas por vírgula
# O servidor recusa inicializar em NODE_ENV=production sem esta variável
# Em desenvolvimento: pode ser omitido (CORS aberto com aviso no log)
ALLOWED_ORIGINS=http://localhost:44000

# ------ Evolution API (WhatsApp) ------
# Pode ser configurado pela UI em Ajustes > Integração WhatsApp
EVOLUTION_API_URL=https://seu-evolution.com
EVOLUTION_GLOBAL_APIKEY=sua_chave_global
EVOLUTION_INSTANCE_NAME=crm_instance

# [OPCIONAL] Rejeita webhooks sem assinatura HMAC válida (fail-closed)
# true  = seguro — recomendado em produção com Evolution API configurada
# false = compatível — permite webhooks sem assinatura (padrão)
WEBHOOK_HMAC_REQUIRED=false

# ------ MinIO S3 (Storage de Mídias) ------
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=chat-crm-media
S3_REGION=us-east-1

# ------ Portas (opcionais - valores padrão mostrados) ------
API_PORT=44001
WEB_PORT=44000

# ------ URLs Públicas ------
# Local (docker-compose.prod.yml):
PUBLIC_API_URL=http://localhost:44001/api
NEXT_PUBLIC_API_URL=http://localhost:44001/api
NEXT_PUBLIC_WS_URL=http://localhost:44001

# Produção (exemplo com Traefik):
# NODE_ENV=production
# PUBLIC_API_URL=https://lexcon.com.br/api
# NEXT_PUBLIC_API_URL=https://lexcon.com.br/api
# NEXT_PUBLIC_WS_URL=wss://lexcon.com.br
# ALLOWED_ORIGINS=https://lexcon.com.br
# WEBHOOK_HMAC_REQUIRED=true
