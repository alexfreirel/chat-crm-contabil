# ============================================
# LexCRM - Variaveis de Ambiente (VPS)
# ============================================

# IP publico da VPS (usado para montar URLs do frontend)
VPS_IP=SEU_IP_AQUI

# ------ Banco de Dados ------
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
POSTGRES_DB=lexcrm

# ------ JWT Auth ------
JWT_SECRET=TROQUE_POR_UMA_SECRET_FORTE_AQUI
JWT_EXPIRES_IN=15m

# ------ Evolution API (WhatsApp) ------
EVOLUTION_API_URL=http://seu-evolution.com
EVOLUTION_GLOBAL_APIKEY=sua_chave_global
EVOLUTION_INSTANCE_NAME=crm_instance

# ------ Google Gemini (IA) ------
GEMINI_API_KEY=sua_chave_gemini

# ------ SeaweedFS S3 (Storage de Midias) ------
S3_ACCESS_KEY=some_access_key
S3_SECRET_KEY=some_secret_key
S3_BUCKET=chat-crm-media

# ------ Portas (opcionais - valores padrao) ------
API_PORT=3001
WEB_PORT=3000

# ------ URLs do Frontend ------
# Substitua SEU_IP_AQUI pelo IP da sua VPS
NEXT_PUBLIC_API_URL=http://SEU_IP_AQUI:3001
NEXT_PUBLIC_WS_URL=ws://SEU_IP_AQUI:3001
