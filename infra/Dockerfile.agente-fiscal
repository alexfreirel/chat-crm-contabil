FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl && rm -rf /var/lib/apt/lists/*

COPY apps/agente-fiscal/requirements.txt .
RUN pip install --no-cache-dir flask gunicorn -r requirements.txt

COPY apps/agente-fiscal/ .

RUN mkdir -p /app/downloads /app/empresas_data

ENV FLASK_APP=app.py
ENV PYTHONUNBUFFERED=1
ENV TZ=America/Sao_Paulo
ENV EMPRESAS_DATA_DIR=/app/empresas_data

EXPOSE 5000

CMD ["gunicorn", "--bind", "0.0.0.0:5000", "--workers", "2", "--threads", "4", "--timeout", "300", "app:app"]
