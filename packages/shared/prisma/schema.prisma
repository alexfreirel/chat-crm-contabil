generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            String         @id @default(uuid())
  name          String
  conversations Conversation[]
  leads         Lead[]
  tasks         Task[]
  users         User[]
  inboxes       Inbox[]
  instances     Instance[]
}

model User {
  id              String         @id @default(uuid())
  tenant_id       String?
  name            String
  email           String         @unique
  password_hash   String
  role            String
  created_at      DateTime       @default(now())
  audit_logs      AuditLog[]
  assigned_convos Conversation[]
  inboxes         Inbox[]
  tasks           Task[]
  tenant          Tenant?        @relation(fields: [tenant_id], references: [id])
}

model Lead {
  id            String         @id @default(uuid())
  tenant_id     String?
  name          String?
  phone         String         @unique
  email         String?
  origin        String?
  stage              String         @default("NOVO")
  profile_picture_url String?
  tags               String[]
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  memory        AiMemory?
  conversations Conversation[]
  tenant        Tenant?        @relation(fields: [tenant_id], references: [id])
  tasks         Task[]

  @@index([tenant_id, phone])
  @@index([stage])
}

model Conversation {
  id               String    @id @default(uuid())
  tenant_id        String?
  lead_id          String
  channel          String    @default("whatsapp")
  external_id      String?
  status           String    @default("ABERTO")
  ai_mode          Boolean   @default(true)
  assigned_user_id String?
  inbox_id         String?
  instance_name    String?   // Nome da instância de origem (ex: wa1)
  last_message_at  DateTime  @default(now())
  assigned_user    User?     @relation(fields: [assigned_user_id], references: [id])
  lead             Lead      @relation(fields: [lead_id], references: [id])
  tenant           Tenant?   @relation(fields: [tenant_id], references: [id])
  inbox            Inbox?    @relation(fields: [inbox_id], references: [id])
  messages         Message[]
  tasks            Task[]

  @@index([lead_id])
  @@index([last_message_at(sort: Desc)])
  @@index([instance_name])
}

model Message {
  id                  String       @id @default(uuid())
  conversation_id     String
  direction           String
  type                String
  text                String?
  external_message_id String?      @unique
  status              String
  created_at          DateTime     @default(now())
  media               Media?
  conversation        Conversation @relation(fields: [conversation_id], references: [id])
  tasks               Task[]

  @@index([conversation_id, created_at])
  @@index([external_message_id])
}

model Media {
  id           String   @id @default(uuid())
  message_id   String   @unique
  s3_key       String
  mime_type    String
  size         Int?
  duration     Int?
  checksum     String?
  original_url String?
  created_at   DateTime @default(now())
  message      Message  @relation(fields: [message_id], references: [id])
}

model Task {
  id               String        @id @default(uuid())
  tenant_id        String?
  lead_id          String?
  conversation_id  String?
  message_id       String?
  title            String
  description      String?
  due_at           DateTime?
  status           String        @default("A_FAZER")
  assigned_user_id String?
  created_at       DateTime      @default(now())
  assigned_user    User?         @relation(fields: [assigned_user_id], references: [id])
  conversation     Conversation? @relation(fields: [conversation_id], references: [id])
  lead             Lead?         @relation(fields: [lead_id], references: [id])
  message          Message?      @relation(fields: [message_id], references: [id])
  tenant           Tenant?       @relation(fields: [tenant_id], references: [id])

  @@index([assigned_user_id, due_at])
  @@index([status])
}

model AiMemory {
  id              String   @id @default(uuid())
  lead_id         String   @unique
  summary         String
  facts_json      Json     @default("{}")
  last_updated_at DateTime @default(now())
  version         Int      @default(1)
  lead            Lead     @relation(fields: [lead_id], references: [id])
}

model PromptSkill {
  id                String  @id @default(uuid())
  name              String
  area              String
  system_prompt     String
  tools_policy_json Json    @default("[]")
  version           Int     @default(1)
  active            Boolean @default(true)
}

model AuditLog {
  id            String   @id @default(uuid())
  actor_user_id String?
  action        String
  entity        String
  entity_id     String
  meta_json     Json?
  created_at    DateTime @default(now())
  actor         User?    @relation(fields: [actor_user_id], references: [id])
}

model GlobalSetting {
  key   String @id
  value String
}

model Inbox {
  id            String         @id @default(uuid())
  tenant_id     String?
  name          String
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  tenant        Tenant?        @relation(fields: [tenant_id], references: [id])
  users         User[]
  conversations Conversation[]
  instances     Instance[]

  @@index([tenant_id])
}

model Instance {
  id            String   @id @default(uuid())
  tenant_id     String?
  inbox_id      String?
  name          String   @unique
  type          String   @default("whatsapp")
  connection    String   @default("evolution")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  tenant        Tenant?  @relation(fields: [tenant_id], references: [id])
  inbox         Inbox?   @relation(fields: [inbox_id], references: [id])

  @@index([tenant_id])
  @@index([inbox_id])
}
