generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                 String              @id @default(uuid())
  name               String
  conversations      Conversation[]
  leads              Lead[]
  tasks              Task[]
  users              User[]
  inboxes            Inbox[]
  instances          Instance[]
  clientes_contabil  ClienteContabil[]
  calendar_events    CalendarEvent[]
  appointment_types  AppointmentType[]
  holidays           Holiday[]
  documentos_contabil DocumentoContabil[]
  obrigacoes_fiscais ObrigacaoFiscal[]
  honorarios_contabil HonorarioContabil[]
  templates_contabil TemplateContabil[]
  ai_chats           AiChat[]
  followup_sequences FollowupSequence[]
  broadcast_jobs     BroadcastJob[]
  financial_transactions FinancialTransaction[]
  financial_categories FinancialCategory[]
  payment_gateway_customers PaymentGatewayCustomer[]
  payment_gateway_charges PaymentGatewayCharge[]
  notas_fiscais      NotaFiscal[]
  tax_records        TaxRecord[]
}

model User {
  id                       String                 @id @default(uuid())
  tenant_id                String?
  name                     String
  email                    String                 @unique
  phone                    String?
  password_hash            String
  role                     String                 @default("ADMIN")
  // Roles: ADMIN | ESPECIALISTA | ASSISTENTE | OPERADOR
  specialties              String[]               @default([])
  created_at               DateTime               @default(now())
  updated_at               DateTime               @updatedAt
  audit_logs               AuditLog[]
  assigned_convos          Conversation[]         @relation("AssignedUser")
  accountant_convos        Conversation[]         @relation("AssignedAccountant")
  lead_notes               LeadNote[]
  stage_history_actor      LeadStageHistory[]     @relation("StageHistoryActor")
  inboxes                  Inbox[]
  sectors                  Sector[]               @relation("SectorUsers")
  tasks                    Task[]
  tenant                   Tenant?                @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  accountant_clientes      ClienteContabil[]      @relation("AccountantClientes")
  task_comments            TaskComment[]
  supervisors              User[]                 @relation("InternSupervisors")
  interns                  User[]                 @relation("InternSupervisors")
  calendar_events_assigned CalendarEvent[]        @relation("EventAssigned")
  calendar_events_created  CalendarEvent[]        @relation("EventCreator")
  schedules                UserSchedule[]
  calendar_event_comments  CalendarEventComment[]
  transfer_audios          TransferAudio[]        @relation("AudioUploader")
  uploaded_documents       DocumentoContabil[]    @relation("DocumentUploader")
  responsavel_obrigacoes   ObrigacaoFiscal[]      @relation("ResponsavelObrigacoes")
  ai_chats                 AiChat[]               @relation("AiChatOwner")
  cs_leads                 Lead[]                 @relation("CSManager")
  financial_transactions   FinancialTransaction[] @relation("FinancialLawyer")
  tax_records              TaxRecord[]            @relation("TaxRecordLawyer")
  conversation_notes       ConversationNote[]     @relation("ConversationNoteAuthor")
  broadcast_jobs           BroadcastJob[]
}

model Lead {
  id                   String               @id @default(uuid())
  tenant_id            String?
  name                 String?
  phone                String               @unique
  email                String?
  origin               String?
  stage                String               @default("NOVO")
  stage_entered_at     DateTime             @default(now())
  loss_reason          String?
  profile_picture_url  String?
  tags                 String[]
  created_at           DateTime             @default(now())
  updated_at           DateTime             @updatedAt

  // ─── Separação Lead vs Cliente ────────────────────────────
  // Quando true: lead se tornou cliente (contrato assinado/FINALIZADO)
  is_client            Boolean              @default(false)
  became_client_at     DateTime?
  // Operador que fechou a venda — mantém vínculo pós-conversão
  cs_user_id           String?
  cs_user              User?                @relation("CSManager", fields: [cs_user_id], references: [id], onDelete: SetNull)

  // Google Drive
  google_drive_folder_id String?

  memory               AiMemory?
  conversations        Conversation[]
  tenant               Tenant?              @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  tasks                Task[]
  clientes_contabil    ClienteContabil[]
  ficha_contabil       FichaContabil?
  calendar_events      CalendarEvent[]
  last_followup_at     DateTime?
  notes                LeadNote[]
  stage_history        LeadStageHistory[]
  contract_signatures  ContractSignature[]
  followup_enrollments      FollowupEnrollment[]
  financial_transactions    FinancialTransaction[]
  payment_gateway_customers PaymentGatewayCustomer[]
  notas_fiscais             NotaFiscal[]
  broadcast_items           BroadcastItem[]
  cpf_cnpj                  String? // CPF ou CNPJ — facilita match com Asaas

  @@index([tenant_id, phone])
  @@index([stage])
  @@index([cpf_cnpj])
  @@index([is_client])
}

model Conversation {
  id                         String              @id @default(uuid())
  tenant_id                  String?
  lead_id                    String
  channel                    String              @default("whatsapp")
  external_id                String?
  status                     String              @default("ABERTO")
  ai_mode                    Boolean             @default(true)
  ai_mode_disabled_at        DateTime?           // Timestamp de quando ai_mode foi desligado (para auto-reativação)
  assigned_user_id           String?
  inbox_id                   String?
  instance_name              String?
  pending_transfer_to_id     String?
  pending_transfer_from_id   String?
  pending_transfer_reason    String?
  pending_transfer_audio_ids String[]            @default([])
  service_type               String?             // Tipo de serviço contábil detectado pela IA
  assigned_accountant_id     String?             // Especialista pré-designado pela IA
  origin_assigned_user_id    String?
  next_step                  String?             // "duvidas" | "triagem_concluida" | "formulario" | "reuniao" | "encerrado"
  ai_notes                   String?
  reminder_context           Json?
  last_message_at            DateTime            @default(now())
  assigned_user              User?               @relation("AssignedUser", fields: [assigned_user_id], references: [id], onDelete: SetNull)
  assigned_accountant        User?               @relation("AssignedAccountant", fields: [assigned_accountant_id], references: [id], onDelete: SetNull)
  lead                       Lead                @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  tenant                     Tenant?             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  inbox                      Inbox?              @relation(fields: [inbox_id], references: [id], onDelete: SetNull)
  messages                   Message[]
  tasks                      Task[]
  clientes_contabil          ClienteContabil[]
  calendar_events            CalendarEvent[]
  transfer_audios            TransferAudio[]
  contract_signatures        ContractSignature[]
  notes                      ConversationNote[]

  @@index([lead_id])
  @@index([last_message_at(sort: Desc)])
  @@index([instance_name])
  @@index([tenant_id])
  @@index([assigned_user_id])
  @@index([status])
  @@index([pending_transfer_to_id])
  @@index([inbox_id])
}

model Message {
  id                  String            @id @default(uuid())
  conversation_id     String
  direction           String
  type                String
  text                String?
  external_message_id String?           @unique
  status              String
  created_at          DateTime          @default(now())
  reply_to_id         String?
  reply_to_text       String?
  skill_id            String?
  media               Media?
  reactions           MessageReaction[]
  conversation        Conversation      @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  reply_to            Message?          @relation("MessageReplies", fields: [reply_to_id], references: [id], onDelete: SetNull)
  replies             Message[]         @relation("MessageReplies")
  skill               PromptSkill?      @relation(fields: [skill_id], references: [id], onDelete: SetNull)
  tasks               Task[]

  @@index([conversation_id, created_at])
  @@index([external_message_id])
}

model MessageReaction {
  id          String   @id @default(uuid())
  message_id  String
  user_id     String?
  contact_jid String?
  emoji       String
  created_at  DateTime @default(now())
  message     Message  @relation(fields: [message_id], references: [id], onDelete: Cascade)

  @@unique([message_id, user_id])
  @@unique([message_id, contact_jid])
  @@index([message_id])
}

model Media {
  id            String   @id @default(uuid())
  message_id    String   @unique
  s3_key        String
  mime_type     String
  size          Int?
  duration      Int?
  checksum      String?
  original_url  String?
  original_name String?
  created_at    DateTime @default(now())
  message       Message  @relation(fields: [message_id], references: [id], onDelete: Cascade)
}

model Task {
  id                    String              @id @default(uuid())
  tenant_id             String?
  lead_id               String?
  conversation_id       String?
  message_id            String?
  cliente_contabil_id   String?
  calendar_event_id     String?             @unique
  title                 String
  description           String?
  due_at                DateTime?
  status                String              @default("A_FAZER")
  assigned_user_id      String?
  created_at            DateTime            @default(now())
  completion_note       String?
  postpone_count        Int                 @default(0)
  created_by_id         String?
  assigned_user         User?               @relation(fields: [assigned_user_id], references: [id], onDelete: SetNull)
  conversation          Conversation?       @relation(fields: [conversation_id], references: [id], onDelete: SetNull)
  lead                  Lead?               @relation(fields: [lead_id], references: [id], onDelete: SetNull)
  message               Message?            @relation(fields: [message_id], references: [id], onDelete: SetNull)
  tenant                Tenant?             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  cliente_contabil      ClienteContabil?    @relation(fields: [cliente_contabil_id], references: [id], onDelete: SetNull)
  calendar_event        CalendarEvent?      @relation(fields: [calendar_event_id], references: [id], onDelete: SetNull)
  comments              TaskComment[]
  checklist_items       TaskChecklistItem[]
  postponements         TaskPostponement[]

  @@index([assigned_user_id, due_at])
  @@index([status])
  @@index([cliente_contabil_id])
  @@index([tenant_id])
  @@index([lead_id])
}

model TaskPostponement {
  id            String   @id @default(uuid())
  task_id       String
  task          Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  old_due_at    DateTime
  new_due_at    DateTime
  reason        String
  created_by_id String?
  created_at    DateTime @default(now())

  @@index([task_id])
}

model AiMemory {
  id              String   @id @default(uuid())
  lead_id         String   @unique
  summary         String
  facts_json      Json     @default("{}")
  last_updated_at DateTime @default(now())
  version         Int      @default(1)
  lead            Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade)
}

model PromptSkill {
  id                 String       @id @default(uuid())
  name               String
  area               String
  system_prompt      String
  tools_policy_json  Json         @default("[]")
  version            Int          @default(1)
  active             Boolean      @default(true)
  model              String       @default("gpt-4o-mini")
  max_tokens         Int          @default(300)
  temperature        Float        @default(0.7)
  handoff_signal     String?
  order              Int          @default(0)
  description        String?
  trigger_keywords   String[]     @default([])
  skill_type         String       @default("specialist")
  max_context_tokens Int          @default(4000)
  provider           String       @default("openai")
  created_at         DateTime     @default(now())
  updated_at         DateTime     @updatedAt
  messages           Message[]
  tools              SkillTool[]
  assets             SkillAsset[]
}

model SkillTool {
  id              String      @id @default(uuid())
  skill_id        String
  name            String
  description     String
  parameters_json Json
  handler_type    String      // "builtin" | "webhook"
  handler_config  Json        @default("{}")
  active          Boolean     @default(true)
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt
  skill           PromptSkill @relation(fields: [skill_id], references: [id], onDelete: Cascade)

  @@unique([skill_id, name])
  @@index([skill_id])
}

model SkillAsset {
  id           String      @id @default(uuid())
  skill_id     String
  name         String
  s3_key       String
  mime_type    String
  size         Int
  asset_type   String      // "asset" | "reference"
  inject_mode  String      @default("none")
  content_text String?
  created_at   DateTime    @default(now())
  skill        PromptSkill @relation(fields: [skill_id], references: [id], onDelete: Cascade)

  @@index([skill_id, asset_type])
}

model SkillExecutionLog {
  id               String   @id @default(uuid())
  conversation_id  String
  skill_id         String?
  tool_calls_json  Json?
  selection_reason String?
  router_tokens    Int?
  duration_ms      Int?
  created_at       DateTime @default(now())

  @@index([conversation_id, created_at])
  @@index([skill_id])
}

model AuditLog {
  id            String   @id @default(uuid())
  actor_user_id String?
  action        String
  entity        String
  entity_id     String
  meta_json     Json?
  created_at    DateTime @default(now())
  actor         User?    @relation(fields: [actor_user_id], references: [id], onDelete: SetNull)

  @@index([actor_user_id, created_at])
  @@index([entity, entity_id])
}

model GlobalSetting {
  key        String   @id
  value      String
  updated_at DateTime @updatedAt
}

model AiUsage {
  id                String   @id @default(uuid())
  conversation_id   String?
  skill_id          String?
  model             String
  call_type         String   // 'chat' | 'memory' | 'whisper'
  prompt_tokens     Int      @default(0)
  completion_tokens Int      @default(0)
  total_tokens      Int      @default(0)
  cost_usd          Float    @default(0)
  created_at        DateTime @default(now())

  @@index([created_at])
  @@index([model])
  @@index([conversation_id])
}

model Inbox {
  id            String         @id @default(uuid())
  tenant_id     String?
  name          String
  rr_pointer    String?
  is_active     Boolean        @default(true)
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  tenant        Tenant?        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  users         User[]
  conversations Conversation[]
  instances     Instance[]

  @@index([tenant_id])
}

model Instance {
  id         String   @id @default(uuid())
  tenant_id  String?
  inbox_id   String?
  name       String   @unique
  type       String   @default("whatsapp")
  connection String   @default("evolution")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  tenant     Tenant?  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  inbox      Inbox?   @relation(fields: [inbox_id], references: [id], onDelete: SetNull)

  @@index([tenant_id])
  @@index([inbox_id])
}

model TransferAudio {
  id              String   @id @default(uuid())
  conversation_id String
  s3_key          String
  mime_type       String   @default("audio/webm")
  size            Int?
  uploaded_by_id  String?
  expires_at      DateTime
  created_at      DateTime @default(now())

  conversation Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  uploaded_by  User?        @relation("AudioUploader", fields: [uploaded_by_id], references: [id], onDelete: SetNull)

  @@index([conversation_id])
  @@index([expires_at])
}

model LpEvent {
  id           String   @id @default(uuid())
  page_path    String
  event_type   String   // "view" | "whatsapp_click"
  visitor_id   String?
  utm_source   String?
  utm_medium   String?
  utm_campaign String?
  utm_term     String?
  utm_content  String?
  gclid        String?
  referrer     String?
  created_at   DateTime @default(now())

  @@index([page_path, created_at])
  @@index([event_type])
}

model Sector {
  id         String   @id @default(uuid())
  name       String
  auto_route Boolean  @default(false)
  created_at DateTime @default(now())
  users      User[]   @relation("SectorUsers")
}

// ===============================================
// MÓDULO CONTÁBIL — Cliente Contábil
// Substitui LegalCase
// ===============================================

model ClienteContabil {
  id                String    @id @default(uuid())
  tenant_id         String?
  lead_id           String
  conversation_id   String?
  accountant_id     String?
  // Identificação fiscal
  cpf_cnpj          String?
  tipo_pessoa       String?   // PF | PJ
  // Serviço contábil
  service_type      String    // BPO_FISCAL | BPO_CONTABIL | DP | ABERTURA | ENCERRAMENTO | IR_PF | IR_PJ | CONSULTORIA | OUTRO
  regime_tributario String?   // SIMPLES_NACIONAL | LUCRO_PRESUMIDO | LUCRO_REAL | MEI | ISENTO
  competencia_inicio DateTime?
  data_encerramento  DateTime?
  stage             String    @default("ONBOARDING") // ONBOARDING | ATIVO | SUSPENSO | ENCERRADO
  priority          String    @default("NORMAL")     // URGENTE | NORMAL | BAIXA
  notes             String?
  archived          Boolean   @default(false)
  archive_reason    String?
  stage_changed_at  DateTime  @default(now())
  // Endereço
  cep               String?
  logradouro        String?
  numero            String?
  complemento       String?
  bairro            String?
  cidade            String?
  estado            String?
  // Integração
  google_drive_folder_id String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  lead         Lead          @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversation_id], references: [id], onDelete: SetNull)
  accountant   User?         @relation("AccountantClientes", fields: [accountant_id], references: [id], onDelete: SetNull)
  tenant       Tenant?       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  tasks      Task[]
  calendar_events CalendarEvent[]
  documentos DocumentoContabil[]
  obrigacoes ObrigacaoFiscal[]
  honorarios HonorarioContabil[]
  eventos    ClienteEvento[]

  @@index([tenant_id])
  @@index([lead_id])
  @@index([stage])
  @@index([accountant_id])
  @@index([archived])
}

model ClienteEvento {
  id          String          @id @default(uuid())
  cliente_id  String
  type        String          // INICIO_SERVICO | MUDANCA_REGIME | DOCUMENTACAO | REUNIAO | OUTRO
  title       String
  description String?
  event_date  DateTime?
  created_at  DateTime        @default(now())

  cliente ClienteContabil @relation(fields: [cliente_id], references: [id], onDelete: Cascade)

  @@index([cliente_id, created_at])
}

// ===============================================
// Ficha Contábil do Cliente
// Substitui FichaTrabalhista
// ===============================================

model FichaContabil {
  id                     String    @id @default(uuid())
  lead_id                String    @unique
  // Dados da Empresa / Pessoa
  razao_social           String?
  nome_fantasia          String?
  cnpj                   String?
  cpf                    String?
  data_abertura          DateTime?
  regime_tributario      String?   // SIMPLES_NACIONAL | LUCRO_PRESUMIDO | LUCRO_REAL | MEI | ISENTO
  porte                  String?   // MEI | ME | EPP | MEDIO | GRANDE
  natureza_juridica      String?
  cnae_principal         String?
  cnae_secundarios       String[]  @default([])
  inscricao_estadual     String?
  inscricao_municipal    String?
  // Endereço
  cep                    String?
  logradouro             String?
  numero                 String?
  complemento            String?
  bairro                 String?
  cidade                 String?
  estado                 String?
  // Contatos da empresa
  email_contabil         String?
  email_fiscal           String?
  telefone_empresa       String?
  // Dados Financeiros / Acessos
  banco                  String?
  agencia                String?
  conta                  String?
  vencimento_certificado DateTime?
  acesso_prefeitura      String?
  acesso_sefaz           String?
  acesso_receita         String?
  // Departamento Pessoal
  tem_funcionarios       Boolean   @default(false)
  qtd_funcionarios       Int?
  tem_pro_labore         Boolean   @default(false)
  regime_contratacao     String?   // CLT | PJ | AUTONOMO | MISTO
  // Sócios (JSON: [{nome, cpf, percentual, pro_labore}])
  socios                 Json?
  // Faturamento estimado
  faturamento_mensal     Decimal?  @db.Decimal(15, 2)
  faturamento_anual      Decimal?  @db.Decimal(15, 2)
  // Sistemas utilizados
  sistema_erp            String?
  sistema_nf             String?   // Software de emissão de NF
  sistema_folha          String?   // Software de folha de pagamento
  // Contabilidade anterior
  escritorio_anterior    String?
  data_transicao         DateTime? // Data prevista de início/transição
  // Observações
  observacoes            String?
  // Serviços contratados
  servicos               String[]  @default([])
  // BPO_FISCAL | BPO_CONTABIL | DP | ABERTURA | IR_PF | IR_PJ | CONSULTORIA | OUTRO
  // Status do preenchimento
  status                 String    @default("pendente") // pendente | em_andamento | completo
  completion_pct         Int       @default(0)
  finalizado             Boolean   @default(false)
  filled_by              String    @default("manual") // "manual" | "ai" | "cliente"
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  lead Lead @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  @@index([lead_id])
  @@index([cnpj])
  @@index([finalizado])
}

// ===============================================
// Obrigações Fiscais / Acessórias
// Substitui CaseDeadline
// ===============================================

model ObrigacaoFiscal {
  id                String    @id @default(uuid())
  tenant_id         String?
  cliente_id        String
  responsavel_id    String?
  // Tipo de obrigação
  tipo              String
  // DAS_MENSAL | PGDAS | SPED_FISCAL | EFD_CONTRIB | ECF | ECD | DCTF
  // DEFIS | DASN | DIRF | RAIS | eSocial | FGTS | FOLHA | IRPF
  // NOTA_FISCAL | CERTIDAO | OUTRO
  titulo            String
  competencia       DateTime? // Mês de referência (ex: 2025-03-01)
  due_at            DateTime
  recorrente        Boolean   @default(false)
  frequencia        String?   // MENSAL | TRIMESTRAL | SEMESTRAL | ANUAL
  completed         Boolean   @default(false)
  completed_at      DateTime?
  alert_days        Int       @default(3)
  calendar_event_id String?   @unique
  created_at        DateTime  @default(now())

  cliente       ClienteContabil @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  responsavel   User?           @relation("ResponsavelObrigacoes", fields: [responsavel_id], references: [id], onDelete: SetNull)
  tenant        Tenant?         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([cliente_id, due_at])
  @@index([completed, due_at])
  @@index([tenant_id])
}

// ===============================================
// Documentos Contábeis
// Substitui CaseDocument
// ===============================================

model DocumentoContabil {
  id             String    @id @default(uuid())
  tenant_id      String?
  cliente_id     String
  uploaded_by_id String?
  // Pastas contábeis
  folder         String    @default("OUTROS")
  // CONTRATO | PROCURACAO | CERTIDAO | NOTA_FISCAL | SPED | FOLHA | IR | CNPJ | SOCIOS | OUTROS
  name           String
  original_name  String
  s3_key         String
  mime_type      String?
  size           Int?
  description    String?
  created_at     DateTime  @default(now())

  cliente     ClienteContabil @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  uploaded_by User?           @relation("DocumentUploader", fields: [uploaded_by_id], references: [id], onDelete: SetNull)
  tenant      Tenant?         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([cliente_id, folder])
  @@index([tenant_id])
}

// ===============================================
// Honorários Contábeis
// Substitui CaseHonorario + HonorarioPayment
// ===============================================

model HonorarioContabil {
  id             String    @id @default(uuid())
  tenant_id      String?
  cliente_id     String
  tipo           String    // MENSALIDADE | SERVICO_AVULSO | IMPLANTACAO
  valor          Decimal   @db.Decimal(10, 2)
  dia_vencimento Int?      // 1-31 (dia do mês para mensalidade)
  ativo          Boolean   @default(true)
  notas          String?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  cliente  ClienteContabil   @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  tenant   Tenant?           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  parcelas HonorarioParcela[]

  @@index([cliente_id])
  @@index([tenant_id])
}

model HonorarioParcela {
  id             String    @id @default(uuid())
  honorario_id   String
  competencia    DateTime? // Mês de referência (ex: 2025-03-01)
  amount         Decimal   @db.Decimal(10, 2)
  due_date       DateTime
  paid_at        DateTime?
  payment_method String?   // PIX | BOLETO | TED | CARTAO | DINHEIRO
  status         String    @default("PENDENTE") // PENDENTE | PAGO | ATRASADO
  notas          String?
  created_at     DateTime  @default(now())

  honorario HonorarioContabil @relation(fields: [honorario_id], references: [id], onDelete: Cascade)

  @@index([honorario_id, due_date])
  @@index([status])
}

// ===============================================
// Templates de Documentos Contábeis
// Substitui LegalTemplate
// ===============================================

model TemplateContabil {
  id            String   @id @default(uuid())
  tenant_id     String?
  name          String
  tipo          String   // CONTRATO_SERVICO | PROCURACAO | PROPOSTA | NOTIFICACAO | OUTRO
  content_json  Json?    // Tiptap JSON com placeholders {{razao_social}}, {{cnpj}}, etc.
  variables     String[] @default([])
  description   String?
  is_global     Boolean  @default(false)
  usage_count   Int      @default(0)
  created_by_id String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([tipo])
}

// ===============================================
// Follow-up IA — Sequências e Envios
// ===============================================

model FollowupSequence {
  id                 String               @id @default(cuid())
  tenant_id          String?
  name               String
  description        String?
  category           String               @default("LEADS") // LEADS | CLIENTS | COBRANCA | REENGAJAMENTO
  active             Boolean              @default(true)
  auto_enroll_stages String[]             @default([])
  max_attempts       Int                  @default(6)
  created_at         DateTime             @default(now())
  updated_at         DateTime             @updatedAt
  tenant             Tenant?              @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  steps              FollowupStep[]
  enrollments        FollowupEnrollment[]
}

model FollowupStep {
  id            String            @id @default(cuid())
  sequence_id   String
  position      Int
  delay_hours   Int               @default(24)
  channel       String            @default("whatsapp")
  tone          String            @default("amigavel")
  objective     String
  custom_prompt String?           @db.Text
  auto_send     Boolean           @default(true)
  created_at    DateTime          @default(now())
  sequence      FollowupSequence  @relation(fields: [sequence_id], references: [id], onDelete: Cascade)
  messages      FollowupMessage[]

  @@index([sequence_id, position])
}

model FollowupEnrollment {
  id            String            @id @default(cuid())
  lead_id       String
  sequence_id   String
  current_step  Int               @default(1)
  status        String            @default("ATIVO") // ATIVO | PAUSADO | CONCLUIDO | CANCELADO | CONVERTIDO
  enrolled_at   DateTime          @default(now())
  last_sent_at  DateTime?
  next_send_at  DateTime?
  paused_reason String?
  created_at    DateTime          @default(now())
  updated_at    DateTime          @updatedAt
  lead          Lead              @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  sequence      FollowupSequence  @relation(fields: [sequence_id], references: [id], onDelete: Cascade)
  messages      FollowupMessage[]

  @@unique([lead_id, sequence_id])
  @@index([status, next_send_at])
}

model FollowupMessage {
  id             String             @id @default(cuid())
  enrollment_id  String
  step_id        String
  lead_id        String
  channel        String
  generated_text String             @db.Text
  sent_text      String?            @db.Text
  status         String             @default("PENDENTE_APROVACAO")
  approved_by    String?
  approved_at    DateTime?
  sent_at        DateTime?
  context_json   Json?
  risk_level     String             @default("baixo")
  created_at     DateTime           @default(now())
  updated_at     DateTime           @updatedAt
  enrollment     FollowupEnrollment @relation(fields: [enrollment_id], references: [id], onDelete: Cascade)
  step           FollowupStep       @relation(fields: [step_id], references: [id], onDelete: Cascade)

  @@index([enrollment_id])
  @@index([status])
  @@index([lead_id])
}

// ===============================================
// Broadcast / Disparos em Massa
// ===============================================

model BroadcastJob {
  id             String          @id @default(cuid())
  tenant_id      String?
  name           String
  type           String          @default("AUDIENCIA")
  status         String          @default("PENDENTE")
  filter_json    Json?
  custom_prompt  String?         @db.Text
  total_targets  Int             @default(0)
  sent_count     Int             @default(0)
  failed_count   Int             @default(0)
  interval_ms    Int             @default(10000)
  started_at     DateTime?
  completed_at   DateTime?
  created_by_id  String
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt

  tenant         Tenant?         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  created_by     User            @relation(fields: [created_by_id], references: [id])
  items          BroadcastItem[]

  @@index([tenant_id, status])
  @@index([created_at])
}

model BroadcastItem {
  id             String       @id @default(cuid())
  broadcast_id   String
  lead_id        String
  event_id       String?
  phone          String
  generated_text String?      @db.Text
  status         String       @default("PENDENTE")
  sent_at        DateTime?
  error          String?
  created_at     DateTime     @default(now())

  broadcast      BroadcastJob @relation(fields: [broadcast_id], references: [id], onDelete: Cascade)
  lead           Lead         @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  @@index([broadcast_id, status])
  @@index([lead_id])
}

// ===============================================
// Calendar / Agenda
// ===============================================

model CalendarEvent {
  id          String    @id @default(uuid())
  tenant_id   String?
  type        String    // CONSULTA | REUNIAO | PRAZO | OBRIGACAO | OUTRO
  title       String
  description String?
  start_at    DateTime
  end_at      DateTime?
  all_day     Boolean   @default(false)
  status      String    @default("AGENDADO") // AGENDADO | CONFIRMADO | CONCLUIDO | CANCELADO | ADIADO
  priority    String    @default("NORMAL")
  color       String?
  location    String?

  lead_id              String?
  conversation_id      String?
  cliente_contabil_id  String?
  assigned_user_id     String?
  created_by_id        String
  appointment_type_id  String?

  // Recurrence
  recurrence_rule String?
  recurrence_end  DateTime?
  recurrence_days Int[]           @default([])
  parent_event_id String?
  parent_event    CalendarEvent?  @relation("RecurrenceChildren", fields: [parent_event_id], references: [id], onDelete: Cascade)
  child_events    CalendarEvent[] @relation("RecurrenceChildren")

  lead             Lead?            @relation(fields: [lead_id], references: [id], onDelete: SetNull)
  conversation     Conversation?    @relation(fields: [conversation_id], references: [id], onDelete: SetNull)
  cliente_contabil ClienteContabil? @relation(fields: [cliente_contabil_id], references: [id], onDelete: SetNull)
  assigned_user    User?            @relation("EventAssigned", fields: [assigned_user_id], references: [id], onDelete: SetNull)
  created_by       User             @relation("EventCreator", fields: [created_by_id], references: [id])
  appointment_type AppointmentType? @relation(fields: [appointment_type_id], references: [id], onDelete: SetNull)

  reminders EventReminder[]
  comments  CalendarEventComment[]
  task      Task?
  tenant    Tenant?                @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([tenant_id, start_at])
  @@index([assigned_user_id, start_at])
  @@index([lead_id])
  @@index([cliente_contabil_id])
  @@index([parent_event_id])
}

model EventReminder {
  id             String        @id @default(uuid())
  event_id       String
  event          CalendarEvent @relation(fields: [event_id], references: [id], onDelete: Cascade)
  minutes_before Int
  channel        String        @default("PUSH")
  sent_at        DateTime?

  @@index([event_id])
}

model UserSchedule {
  id          String  @id @default(uuid())
  user_id     String
  user        User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  day_of_week Int
  start_time  String
  end_time    String
  lunch_start String?
  lunch_end   String?

  @@unique([user_id, day_of_week])
}

model AppointmentType {
  id        String  @id @default(uuid())
  tenant_id String?
  name      String  // "Consulta BPO 30min", "Reunião de Onboarding", etc.
  duration  Int     // minutos
  color     String?
  active    Boolean @default(true)

  events CalendarEvent[]
  tenant Tenant?         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model Holiday {
  id               String   @id @default(uuid())
  tenant_id        String?
  date             DateTime
  name             String
  recurring_yearly Boolean  @default(false)
  created_at       DateTime @default(now())

  tenant Tenant? @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, date])
}

// ===============================================
// Lead Stage History
// ===============================================

model LeadStageHistory {
  id          String   @id @default(uuid())
  lead_id     String
  from_stage  String?
  to_stage    String
  actor_id    String?
  loss_reason String?
  created_at  DateTime @default(now())

  lead  Lead  @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  actor User? @relation("StageHistoryActor", fields: [actor_id], references: [id], onDelete: SetNull)

  @@index([lead_id, created_at])
}

// ===============================================
// Lead Notes
// ===============================================

model LeadNote {
  id         String   @id @default(uuid())
  lead_id    String
  user_id    String
  text       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  lead Lead @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([lead_id, created_at])
  @@index([user_id])
}

model CalendarEventComment {
  id         String   @id @default(uuid())
  event_id   String
  user_id    String
  text       String
  created_at DateTime @default(now())

  event CalendarEvent @relation(fields: [event_id], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([event_id, created_at])
}

model TaskComment {
  id         String   @id @default(uuid())
  task_id    String
  user_id    String
  text       String
  created_at DateTime @default(now())

  task Task @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([task_id, created_at])
}

model TaskChecklistItem {
  id         String   @id @default(cuid())
  task_id    String
  text       String
  done       Boolean  @default(false)
  position   Int      @default(0)
  created_at DateTime @default(now())

  task Task @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@index([task_id])
}

// ===============================================
// Contract Signatures (Clicksign — mantido)
// ===============================================

model ContractSignature {
  id              String @id @default(uuid())
  lead_id         String
  conversation_id String

  cs_document_key          String  @unique
  cs_signer_key            String?
  cs_request_signature_key String?
  signing_url              String?
  signed_s3_key            String?

  status    String    @default("PENDENTE") // PENDENTE | ASSINADO | CANCELADO | EXPIRADO
  signed_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  lead         Lead         @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([lead_id])
  @@index([conversation_id])
  @@index([cs_document_key])
  @@index([status])
}

// ===============================================
// AI Chat (conversas persistentes de IA)
// ===============================================

model AiChat {
  id           String   @id @default(uuid())
  tenant_id    String?
  user_id      String
  title        String   @default("Nova Conversa")
  model        String   @default("claude-sonnet-4-6")
  container_id String?
  updated_at   DateTime @updatedAt
  created_at   DateTime @default(now())

  user     User            @relation("AiChatOwner", fields: [user_id], references: [id], onDelete: Cascade)
  tenant   Tenant?         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  messages AiChatMessage[]

  @@index([user_id, updated_at])
  @@index([tenant_id])
  @@index([updated_at])
}

model AiChatMessage {
  id         String   @id @default(uuid())
  chat_id    String
  role       String   // 'user' | 'assistant'
  content    String   @db.Text
  files_json Json?
  created_at DateTime @default(now())

  chat AiChat @relation(fields: [chat_id], references: [id], onDelete: Cascade)

  @@index([chat_id, created_at])
}

model AutomationRule {
  id           String   @id @default(cuid())
  tenant_id    String?
  name         String
  trigger      String   // NEW_LEAD | STAGE_CHANGE | NO_RESPONSE_24H | NO_RESPONSE_48H | PAYMENT_OVERDUE
  action       String   // ADD_TAG | SEND_INTERNAL_NOTE | CHANGE_STAGE
  action_value String
  enabled      Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([tenant_id])
  @@index([trigger, enabled])
}

// ===============================================
// Módulo Financeiro — Transações e Categorias
// ===============================================

model FinancialTransaction {
  id                   String    @id @default(uuid())
  tenant_id            String?
  type                 String // RECEITA, DESPESA
  category             String // HONORARIO, CONSULTA, CUSTAS_JUDICIAIS, PERICIA, DESLOCAMENTO, ESCRITORIO, OUTRO
  description          String
  amount               Decimal
  date                 DateTime  @default(now()) // data da transação
  due_date             DateTime? // vencimento (para receitas/despesas futuras)
  paid_at              DateTime? // quando foi efetivamente pago/recebido
  payment_method       String? // PIX, BOLETO, CARTAO, DINHEIRO, TRANSFERENCIA
  status               String    @default("PENDENTE") // PENDENTE, PAGO, CANCELADO
  reference_id         String? // ID externo (gateway, NFS-e, etc.)
  notes                String?
  visible_to_lawyer    Boolean   @default(true) // Se false, advogado não vê esta despesa

  // Recorrência
  is_recurring          Boolean   @default(false)
  recurrence_pattern    String?   // MENSAL, TRIMESTRAL, SEMESTRAL, ANUAL
  recurrence_day        Int?      // Dia do mês para vencimento (1-31)
  recurrence_end_date   DateTime? // Quando parar (null = indefinido)
  parent_transaction_id String?   // Referência à transação mãe

  // Vínculos opcionais
  lead_id              String?
  lawyer_id            String?

  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  tenant            Tenant?           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  lead              Lead?             @relation(fields: [lead_id], references: [id], onDelete: SetNull)
  lawyer            User?             @relation("FinancialLawyer", fields: [lawyer_id], references: [id], onDelete: SetNull)
  gateway_charge         PaymentGatewayCharge?
  nota_fiscal       NotaFiscal?

  @@index([tenant_id, date])
  @@index([type, status])
  @@index([lead_id])
  @@index([lawyer_id])
  @@index([category])
  @@index([due_date, status])
}

model FinancialCategory {
  id         String   @id @default(uuid())
  tenant_id  String?
  type       String // RECEITA, DESPESA
  name       String
  icon       String?
  is_default Boolean  @default(false)
  active     Boolean  @default(true)
  created_at DateTime @default(now())

  tenant Tenant? @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, name, type])
  @@index([tenant_id, type])
}

// ===============================================
// Payment Gateway — Asaas / EfiBank
// ===============================================

model PaymentGatewayCustomer {
  id             String    @id @default(uuid())
  tenant_id      String?
  lead_id        String
  gateway        String    @default("ASAAS") // ASAAS, EFIBANK
  external_id    String // ID do cliente no gateway
  cpf_cnpj       String?
  sync_status    String    @default("SYNCED") // SYNCED, ERROR
  last_synced_at DateTime  @default(now())
  created_at     DateTime  @default(now())

  lead   Lead    @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, lead_id, gateway])
  @@unique([gateway, external_id])
  @@index([lead_id])
}

model PaymentGatewayCharge {
  id                   String    @id @default(uuid())
  tenant_id            String?
  transaction_id       String?   @unique
  gateway              String    @default("ASAAS")
  external_id          String    @unique // ID da cobrança no gateway
  customer_external_id String // ID do cliente no gateway
  billing_type         String // PIX, BOLETO, CREDIT_CARD
  amount               Decimal
  due_date             DateTime
  status               String    @default("PENDING") // PENDING, RECEIVED, CONFIRMED, OVERDUE, REFUNDED, DELETED, CANCELLED
  description          String?

  // PIX
  pix_qr_code          String?
  pix_copy_paste       String?
  pix_expiration_date  DateTime?

  // Boleto
  boleto_url           String?
  boleto_barcode       String?

  // Resultado
  invoice_url          String?
  paid_at              DateTime?
  payment_date         DateTime?
  net_value            Decimal?
  webhook_payload      Json?

  idempotency_key      String?   @unique
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  transaction            FinancialTransaction?  @relation(fields: [transaction_id], references: [id], onDelete: SetNull)
  tenant                 Tenant?                @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, status])
  @@index([customer_external_id])
  @@index([due_date, status])
}

// ===============================================
// Nota Fiscal Eletrônica (NFS-e)
// ===============================================

model NotaFiscal {
  id                   String    @id @default(uuid())
  tenant_id            String?
  transaction_id       String?   @unique // 1:1 com FinancialTransaction
  honorario_payment_id String?
  lead_id              String?

  // NFS-e data
  numero               String?
  codigo_verificacao   String?
  status               String    @default("PENDENTE") // PENDENTE, EMITIDA, CANCELADA, ERRO
  servico_codigo       String?   // Código CNAE ou LC 116
  servico_descricao    String    @default("Serviços advocatícios")
  valor                Decimal
  aliquota_iss         Decimal?  @default(5.00)
  valor_iss            Decimal?

  // Tomador (cliente)
  tomador_cpf_cnpj     String?
  tomador_nome         String?
  tomador_email        String?

  // Integração com agregador
  provider             String?   // ENOTAS, NFEIO, FOCUSNFE
  external_id          String?   @unique
  xml_url              String?
  pdf_url              String?
  error_message        String?

  emitida_em           DateTime?
  cancelada_em         DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  transaction          FinancialTransaction? @relation(fields: [transaction_id], references: [id], onDelete: SetNull)
  lead                 Lead?                @relation(fields: [lead_id], references: [id], onDelete: SetNull)
  tenant               Tenant?              @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, status])
  @@index([lead_id])
  @@index([emitida_em])
}

// ===============================================
// Controle Tributário — Carnê-Leão / DARF
// ===============================================

model TaxRecord {
  id               String    @id @default(uuid())
  tenant_id        String?
  lawyer_id        String
  year             Int
  month            Int // 1-12

  total_revenue    Decimal   @default(0)
  total_deductions Decimal   @default(0)
  taxable_income   Decimal   @default(0)
  tax_due          Decimal   @default(0)

  darf_code        String    @default("0190") // Carnê-Leão
  darf_due_date    DateTime?
  darf_paid        Boolean   @default(false)
  darf_paid_at     DateTime?
  notes            String?

  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  lawyer           User      @relation("TaxRecordLawyer", fields: [lawyer_id], references: [id], onDelete: Cascade)
  tenant           Tenant?   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, lawyer_id, year, month])
  @@index([lawyer_id, year])
}

model ConversationNote {
  id              String       @id @default(uuid())
  conversation_id String
  user_id         String
  text            String
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  conversation    Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  user            User         @relation("ConversationNoteAuthor", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([conversation_id, created_at])
}
