generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                String            @id @default(uuid())
  name              String
  conversations     Conversation[]
  leads             Lead[]
  tasks             Task[]
  users             User[]
  inboxes           Inbox[]
  instances         Instance[]
  legal_cases       LegalCase[]
  calendar_events   CalendarEvent[]
  appointment_types AppointmentType[]
  holidays          Holiday[]
}

model User {
  id              String         @id @default(uuid())
  tenant_id       String?
  name            String
  email           String         @unique
  phone           String?
  password_hash   String
  role            String
  specialties     String[]       @default([])
  created_at      DateTime       @default(now())
  audit_logs      AuditLog[]
  assigned_convos Conversation[]
  inboxes         Inbox[]
  sectors         Sector[]       @relation("SectorUsers")
  tasks           Task[]
  tenant          Tenant?        @relation(fields: [tenant_id], references: [id])
  lawyer_cases    LegalCase[]    @relation("LawyerCases")
  task_comments   TaskComment[]
  supervisors     User[]         @relation("InternSupervisors")
  interns         User[]         @relation("InternSupervisors")
  calendar_events_assigned CalendarEvent[] @relation("EventAssigned")
  calendar_events_created  CalendarEvent[] @relation("EventCreator")
  schedules                UserSchedule[]
  calendar_event_comments  CalendarEventComment[]
}

model Lead {
  id            String         @id @default(uuid())
  tenant_id     String?
  name          String?
  phone         String         @unique
  email         String?
  origin        String?
  stage              String         @default("NOVO")
  profile_picture_url String?
  tags               String[]
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  memory             AiMemory?
  conversations      Conversation[]
  tenant             Tenant?            @relation(fields: [tenant_id], references: [id])
  tasks              Task[]
  legal_cases        LegalCase[]
  ficha_trabalhista  FichaTrabalhista?
  calendar_events    CalendarEvent[]
  last_followup_at   DateTime?

  @@index([tenant_id, phone])
  @@index([stage])
}

model Conversation {
  id               String    @id @default(uuid())
  tenant_id        String?
  lead_id          String
  channel          String    @default("whatsapp")
  external_id      String?
  status           String    @default("ABERTO")
  ai_mode          Boolean   @default(true)
  assigned_user_id             String?
  inbox_id                     String?
  instance_name                String?   // Nome da instância de origem (ex: wa1)
  pending_transfer_to_id       String?
  pending_transfer_from_id     String?
  pending_transfer_reason      String?
  pending_transfer_audio_ids   String[]  @default([])
  legal_area                   String?   // Área do direito detectada pela IA
  assigned_lawyer_id           String?   // Advogado pré-designado pela IA
  origin_assigned_user_id      String?   // Quem transferiu (para devolução)
  linked_agent_ids             String[]  @default([])  // Todos os agentes que atenderam
  next_step                    String?   // Próximo passo: "duvidas" | "triagem_concluida" | "formulario" | "reuniao" | "encerrado"
  ai_notes                     String?   // Observações internas da IA (campo notes do JSON)
  last_message_at              DateTime  @default(now())
  assigned_user    User?     @relation(fields: [assigned_user_id], references: [id])
  lead             Lead      @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  tenant           Tenant?   @relation(fields: [tenant_id], references: [id])
  inbox            Inbox?    @relation(fields: [inbox_id], references: [id])
  messages         Message[]
  tasks            Task[]
  legal_cases      LegalCase[]
  calendar_events  CalendarEvent[]

  @@index([lead_id])
  @@index([last_message_at(sort: Desc)])
  @@index([instance_name])
}

model Message {
  id                  String       @id @default(uuid())
  conversation_id     String
  direction           String
  type                String
  text                String?
  external_message_id String?      @unique
  status              String
  created_at          DateTime     @default(now())
  reply_to_id         String?
  reply_to_text       String?
  skill_id            String?      // Qual PromptSkill gerou esta resposta IA
  media               Media?
  reactions           MessageReaction[]
  conversation        Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  tasks               Task[]

  @@index([conversation_id, created_at])
  @@index([external_message_id])
}

model MessageReaction {
  id          String   @id @default(uuid())
  message_id  String
  user_id     String?
  contact_jid String?
  emoji       String
  created_at  DateTime @default(now())
  message     Message  @relation(fields: [message_id], references: [id], onDelete: Cascade)

  @@unique([message_id, user_id])
  @@unique([message_id, contact_jid])
  @@index([message_id])
}

model Media {
  id            String   @id @default(uuid())
  message_id    String   @unique
  s3_key        String
  mime_type     String
  size          Int?
  duration      Int?
  checksum      String?
  original_url  String?
  original_name String?
  created_at    DateTime @default(now())
  message       Message  @relation(fields: [message_id], references: [id], onDelete: Cascade)
}

model Task {
  id                 String         @id @default(uuid())
  tenant_id          String?
  lead_id            String?
  conversation_id    String?
  message_id         String?
  legal_case_id      String?
  calendar_event_id  String?        @unique
  title              String
  description        String?
  due_at             DateTime?
  status             String         @default("A_FAZER")
  assigned_user_id   String?
  created_at         DateTime       @default(now())
  assigned_user      User?          @relation(fields: [assigned_user_id], references: [id])
  conversation       Conversation?  @relation(fields: [conversation_id], references: [id])
  lead               Lead?          @relation(fields: [lead_id], references: [id])
  message            Message?       @relation(fields: [message_id], references: [id])
  tenant             Tenant?        @relation(fields: [tenant_id], references: [id])
  legal_case         LegalCase?     @relation(fields: [legal_case_id], references: [id])
  calendar_event     CalendarEvent? @relation(fields: [calendar_event_id], references: [id])
  comments           TaskComment[]

  @@index([assigned_user_id, due_at])
  @@index([status])
  @@index([legal_case_id])
}

model AiMemory {
  id              String   @id @default(uuid())
  lead_id         String   @unique
  summary         String
  facts_json      Json     @default("{}")
  last_updated_at DateTime @default(now())
  version         Int      @default(1)
  lead            Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade)
}

model PromptSkill {
  id                String  @id @default(uuid())
  name              String
  area              String
  system_prompt     String
  tools_policy_json Json    @default("[]")
  version           Int     @default(1)
  active            Boolean @default(true)
  model             String  @default("gpt-4o-mini")
  max_tokens        Int     @default(300)
  temperature       Float   @default(0.7)
  handoff_signal    String? // Palavra que a IA usa para sinalizar escalada ao humano (ex: "ESCALAR_HUMANO")
  order             Int     @default(0)
}

model AuditLog {
  id            String   @id @default(uuid())
  actor_user_id String?
  action        String
  entity        String
  entity_id     String
  meta_json     Json?
  created_at    DateTime @default(now())
  actor         User?    @relation(fields: [actor_user_id], references: [id])
}

model GlobalSetting {
  key   String @id
  value String
}

model AiUsage {
  id                String   @id @default(uuid())
  conversation_id   String?
  skill_id          String?
  model             String
  call_type         String   // 'chat' | 'memory' | 'whisper'
  prompt_tokens     Int      @default(0)
  completion_tokens Int      @default(0)
  total_tokens      Int      @default(0)
  cost_usd          Float    @default(0)
  created_at        DateTime @default(now())

  @@index([created_at])
  @@index([model])
  @@index([conversation_id])
}

model Inbox {
  id            String         @id @default(uuid())
  tenant_id     String?
  name          String
  rr_pointer    String?        // ID do último usuário atribuído (round-robin)
  is_active     Boolean        @default(true)
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  tenant        Tenant?        @relation(fields: [tenant_id], references: [id])
  users         User[]
  conversations Conversation[]
  instances     Instance[]

  @@index([tenant_id])
}

model Instance {
  id            String   @id @default(uuid())
  tenant_id     String?
  inbox_id      String?
  name          String   @unique
  type          String   @default("whatsapp")
  connection    String   @default("evolution")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  tenant        Tenant?  @relation(fields: [tenant_id], references: [id])
  inbox         Inbox?   @relation(fields: [inbox_id], references: [id])

  @@index([tenant_id])
  @@index([inbox_id])
}

model TransferAudio {
  id             String   @id @default(uuid())
  conversation_id String
  s3_key         String
  mime_type      String   @default("audio/webm")
  size           Int?
  uploaded_by_id String?
  expires_at     DateTime // 7 dias após upload — apagado pelo cron
  created_at     DateTime @default(now())

  @@index([conversation_id])
  @@index([expires_at])
}

model LpEvent {
  id           String   @id @default(uuid())
  page_path    String   // "/", "/geral/arapiraca", "/lp/teste"
  event_type   String   // "view" | "whatsapp_click"
  visitor_id   String?
  utm_source   String?
  utm_medium   String?
  utm_campaign String?
  utm_term     String?
  utm_content  String?
  gclid        String?
  referrer     String?
  created_at   DateTime @default(now())

  @@index([page_path, created_at])
  @@index([event_type])
}

model Sector {
  id         String   @id @default(uuid())
  name       String
  auto_route Boolean  @default(false)
  created_at DateTime @default(now())
  users      User[]   @relation("SectorUsers")
}

model LegalCase {
  id              String         @id @default(uuid())
  tenant_id       String?
  lead_id         String
  conversation_id String?
  lawyer_id       String
  case_number     String?
  legal_area      String?
  stage           String         @default("VIABILIDADE")
  in_tracking     Boolean        @default(false)   // true = passou para menu Processos
  tracking_stage  String?                          // stage dentro do menu Processos
  filed_at        DateTime?                        // quando foi protocolado/ajuizado
  archived        Boolean        @default(false)
  archive_reason  String?
  notes           String?
  court           String?
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  lead              Lead              @relation(fields: [lead_id], references: [id])
  conversation      Conversation?     @relation(fields: [conversation_id], references: [id])
  lawyer            User              @relation("LawyerCases", fields: [lawyer_id], references: [id])
  tenant            Tenant?           @relation(fields: [tenant_id], references: [id])
  tasks             Task[]
  events            CaseEvent[]
  djen_publications DjenPublication[]
  calendar_events   CalendarEvent[]

  @@index([lawyer_id, stage])
  @@index([lead_id])
  @@index([stage])
  @@index([in_tracking])
}

model CaseEvent {
  id            String     @id @default(uuid())
  case_id       String
  type          String
  title         String
  description   String?
  source        String?
  reference_url String?
  event_date    DateTime?
  created_at    DateTime   @default(now())

  legal_case    LegalCase  @relation(fields: [case_id], references: [id], onDelete: Cascade)

  @@index([case_id, created_at])
}

model TaskComment {
  id         String   @id @default(uuid())
  task_id    String
  user_id    String
  text       String
  created_at DateTime @default(now())

  task       Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id])

  @@index([task_id, created_at])
}

model FichaTrabalhista {
  id              String   @id @default(uuid())
  lead_id         String   @unique
  lead            Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  data            Json     @default("{}")    // todos os ~80 campos do formulário
  nome_completo   String?                   // espelho para busca rápida
  nome_empregador String?                   // espelho para busca rápida
  finalizado      Boolean  @default(false)
  filled_by       String   @default("manual") // "manual" | "ai" | "lead"
  completion_pct  Int      @default(0)       // 0-100
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([lead_id])
  @@index([finalizado])
}

model DjenPublication {
  id                    String     @id @default(uuid())
  comunicacao_id        Int        @unique
  data_disponibilizacao DateTime
  numero_processo       String
  classe_processual     String?
  assunto               String?
  tipo_comunicacao      String?
  conteudo              String
  nome_advogado         String?
  raw_json              Json
  legal_case_id         String?
  legal_case            LegalCase? @relation(fields: [legal_case_id], references: [id])
  created_at            DateTime   @default(now())

  @@index([data_disponibilizacao])
  @@index([numero_processo])
  @@index([legal_case_id])
}

// ═══════════════════════════════════════════════
// Calendar / Agenda
// ═══════════════════════════════════════════════

model CalendarEvent {
  id                  String    @id @default(uuid())
  tenant_id           String?
  type                String    // CONSULTA, TAREFA, AUDIENCIA, PRAZO, OUTRO
  title               String
  description         String?
  start_at            DateTime
  end_at              DateTime?
  all_day             Boolean   @default(false)
  status              String    @default("AGENDADO") // AGENDADO, CONFIRMADO, CONCLUIDO, CANCELADO, ADIADO
  priority            String    @default("NORMAL")   // BAIXA, NORMAL, ALTA, URGENTE
  color               String?
  location            String?

  lead_id             String?
  conversation_id     String?
  legal_case_id       String?
  assigned_user_id    String?
  created_by_id       String
  appointment_type_id String?

  // Recurrence
  recurrence_rule     String?   // DAILY, WEEKLY, BIWEEKLY, MONTHLY, CUSTOM
  recurrence_end      DateTime?
  recurrence_days     Int[]     @default([]) // dias da semana para CUSTOM (0-6)
  parent_event_id     String?
  parent_event        CalendarEvent?  @relation("RecurrenceChildren", fields: [parent_event_id], references: [id])
  child_events        CalendarEvent[] @relation("RecurrenceChildren")

  lead                Lead?            @relation(fields: [lead_id], references: [id])
  conversation        Conversation?    @relation(fields: [conversation_id], references: [id])
  legal_case          LegalCase?       @relation(fields: [legal_case_id], references: [id])
  assigned_user       User?            @relation("EventAssigned", fields: [assigned_user_id], references: [id])
  created_by          User             @relation("EventCreator", fields: [created_by_id], references: [id])
  appointment_type    AppointmentType? @relation(fields: [appointment_type_id], references: [id])

  reminders           EventReminder[]
  comments            CalendarEventComment[]
  task                Task?
  tenant              Tenant?          @relation(fields: [tenant_id], references: [id])

  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  @@index([tenant_id, start_at])
  @@index([assigned_user_id, start_at])
  @@index([lead_id])
  @@index([legal_case_id])
  @@index([parent_event_id])
}

model EventReminder {
  id             String        @id @default(uuid())
  event_id       String
  event          CalendarEvent @relation(fields: [event_id], references: [id], onDelete: Cascade)
  minutes_before Int           // 15, 30, 60, 1440 (1 dia)
  channel        String        @default("PUSH") // PUSH, WHATSAPP, EMAIL
  sent_at        DateTime?

  @@index([event_id])
}

model UserSchedule {
  id          String @id @default(uuid())
  user_id     String
  user        User   @relation(fields: [user_id], references: [id])
  day_of_week Int    // 0=dom, 1=seg, ..., 6=sab
  start_time  String // "09:00"
  end_time    String // "18:00"

  @@unique([user_id, day_of_week])
}

model AppointmentType {
  id        String  @id @default(uuid())
  tenant_id String?
  name      String  // "Consulta Trabalhista 30min"
  duration  Int     // minutos
  color     String?
  active    Boolean @default(true)

  events    CalendarEvent[]
  tenant    Tenant?         @relation(fields: [tenant_id], references: [id])
}

model Holiday {
  id               String   @id @default(uuid())
  tenant_id        String?
  date             DateTime
  name             String
  recurring_yearly Boolean  @default(false)
  created_at       DateTime @default(now())

  tenant           Tenant?  @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id, date])
}

model CalendarEventComment {
  id         String        @id @default(uuid())
  event_id   String
  user_id    String
  text       String
  created_at DateTime      @default(now())

  event      CalendarEvent @relation(fields: [event_id], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [user_id], references: [id])

  @@index([event_id, created_at])
}
